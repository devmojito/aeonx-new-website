<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AeonX Digital</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Nunito+Sans:opsz,wght@6..12,400;6..12,500;6..12,600;6..12,700;6..12,800;6..12,900&family=DM+Sans:wght@400;500;600;700&family=Inter:wght@400;500;700&family=Public+Sans:wght@400&display=swap');
:root{
  --ax-orange:#df3f17; --ax-orange-2:#e1541d;
  --ax-ink:#15181e; --ax-text:#23272e; --ax-text-2:#3a4352; --ax-text-3:#526077;
  --ax-line:#d5dae2; --ax-line-2:#e5e7eb; --ax-line-3:#b1bac8;
  --ax-white:#ffffff;
  --ax-font:'Nunito Sans',sans-serif; --ax-font-dm:'DM Sans',sans-serif;
  --ax-font-inter:'Inter',sans-serif; --ax-font-public:'Public Sans',sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box}
html,body{background:#fff;font-family:'Nunito Sans',-apple-system,sans-serif;-webkit-font-smoothing:antialiased}
.ax-page{position:relative;width:100vw;max-width:100vw;height:469.2188vw;margin:0 auto;overflow:hidden;background:#fff}
.ax-page section,.ax-page > section div,.ax-page img,.ax-page span,.ax-page p,.ax-page h1,.ax-page h2,.ax-page h3{position:absolute}
.ax-ico{position:static!important;width:100%;height:100%;display:block;pointer-events:none}
.ax-t{margin:0;white-space:pre-wrap;overflow:visible}
img{border:0}

/* ---- NAV ---- */
.ax-nav{position:fixed;top:0;left:0;width:100vw;height:3.4896vw;z-index:1000;
  background:rgba(255,255,255,.72);backdrop-filter:blur(40px);-webkit-backdrop-filter:blur(40px);
  box-shadow:0 0.2083vw 1.6667vw rgba(223,63,23,.08);display:flex;justify-content:center}
.ax-nav__inner{width:75.0vw;max-width:1440px;height:100%;display:flex;align-items:center;padding:0 1.6667vw;gap:0}
.ax-nav__logo{display:flex;align-items:center;height:1.4062vw;width:3.6979vw;flex:0 0 auto}
.ax-nav__logo .ax-ico{height:100%;width:100%}
.ax-nav__links{display:flex;align-items:center;margin-left:6.0417vw;gap:0}
.ax-nav__link{display:flex;align-items:center;gap:0.3125vw;padding:0 0.7292vw;height:3.4896vw;
  font-family:'Nunito Sans';font-size:0.8333vw;line-height:1.25vw;text-decoration:none;white-space:nowrap}
.ax-nav__chev{width:1.0417vw;height:1.0417vw;display:flex;align-items:center;justify-content:center}
.ax-nav__chev .ax-ico{width:0.5729vw;height:0.3646vw}
.ax-nav__right{display:flex;align-items:center;gap:0.3125vw;margin-left:auto}
.ax-nav__icon-btn{width:1.875vw;height:1.875vw;border:1px solid #d5dae2;border-radius:0.4167vw;background:#fff;
  display:flex;align-items:center;justify-content:center;cursor:pointer;padding:0.3125vw}
.ax-nav__icon-btn:first-child{width:2.5vw}
.ax-nav__icon-btn .ax-ico{width:1.1458vw;height:1.1458vw}
.ax-nav__divider{width:1px;height:1.25vw;background:#e5e7eb;margin:0 0.1562vw}
.ax-nav__btn{height:1.875vw;border-radius:0.4167vw;font-family:'Nunito Sans';font-weight:600;font-size:0.7292vw;
  line-height:1.0417vw;padding:0 1.25vw;cursor:pointer;white-space:nowrap;border:1px solid #d5dae2;background:#fff;color:#3a4352}
.ax-nav__btn--primary{background:#df3f17;color:#fff;border-color:#df3f17}
.ax-nav__burger{display:none;flex-direction:column;justify-content:center;gap:5px;width:44px;height:44px;
  margin-left:auto;background:none;border:none;cursor:pointer;padding:10px}
.ax-nav__burger span{display:block;height:2px;width:24px;background:#23272e;border-radius:2px;transition:transform .3s,opacity .3s}
.ax-nav__burger[aria-expanded="true"] span:nth-child(1){transform:translateY(7px) rotate(45deg)}
.ax-nav__burger[aria-expanded="true"] span:nth-child(2){opacity:0}
.ax-nav__burger[aria-expanded="true"] span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}

@media (max-width:1024px){
  .ax-nav{height:64px}
  .ax-nav__inner{width:100%;max-width:none;padding:0 20px}
  .ax-nav__logo{height:24px;width:64px}
  .ax-nav__burger{display:flex}
  .ax-nav__links,.ax-nav__right{position:absolute;top:64px;left:0;width:100%;flex-direction:column;align-items:flex-start;
    background:#fff;margin:0;padding:0;gap:0;box-shadow:0 12px 24px rgba(0,0,0,.08);
    max-height:0;overflow:hidden;transition:max-height .35s ease}
  .ax-nav__right{top:auto}
  .ax-nav.is-open .ax-nav__links{max-height:340px;padding:8px 0}
  .ax-nav.is-open .ax-nav__right{max-height:240px;padding:8px 20px 20px;gap:12px}
  .ax-nav__link{height:auto;padding:14px 20px;font-size:16px;line-height:1.4;width:100%}
  .ax-nav__chev .ax-ico{width:11px;height:7px}
  .ax-nav__right{position:static;flex-direction:row;flex-wrap:wrap;width:auto;box-shadow:none;max-height:none;
    overflow:visible;margin-left:auto}
  .ax-nav__icon-btn{width:40px;height:40px;border-radius:8px;padding:8px}
  .ax-nav__icon-btn:first-child{width:40px}
  .ax-nav__icon-btn .ax-ico{width:20px;height:20px}
  .ax-nav__divider{height:24px}
  .ax-nav__btn{height:40px;font-size:14px;line-height:20px;padding:0 18px;border-radius:8px}
}
@media (max-width:768px){
  .ax-nav__right{position:absolute;top:64px;left:0;width:100%;flex-direction:column;align-items:stretch;
    background:#fff;max-height:0;overflow:hidden;transition:max-height .35s ease;box-shadow:0 12px 24px rgba(0,0,0,.08);margin:0}
  .ax-nav.is-open .ax-nav__links{box-shadow:none}
  .ax-nav.is-open .ax-nav__right{max-height:300px;padding:12px 20px 20px;gap:10px}
  .ax-nav__divider{display:none}
  .ax-nav__icon-btn,.ax-nav__icon-btn:first-child{width:100%;height:44px;justify-content:flex-start;gap:10px;padding:0 14px}
  .ax-nav__btn{width:100%}
}
</style>
</head>
<body>
<header class="ax-nav">
  <div class="ax-nav__inner">
